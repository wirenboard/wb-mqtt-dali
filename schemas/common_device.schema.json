{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",

  "properties": {
    "name": {
      "type": "string",
      "title": "Device name",
      "minLength": 1,
      "propertyOrder": 0,
      "options": {
        "grid_columns": 6
      }
    },
    "mqtt_id": {
      "type": "string",
      "title": "MQTT id of the device",
      "description": "Used as part of the topic",
      "pattern": "^[^$#+\\/\"']+$",
      "propertyOrder": 1,
      "minLength": 1,
      "options": {
        "patternmessage": "Invalid device ID",
        "grid_columns": 6
      }
    },
    "types": {
      "type": "array",
      "title": "Control Gear Types",
      "propertyOrder": 2,
      "items": {
        "type": "number"
      },
      "options": {
        "wb": {
          "read_only": true
        }
      }
    },
    "brand_name": {
      "type": "string",
      "title": "Brand Name",
      "propertyOrder": 3,
      "options": {
        "grid_columns": 6,
        "wb": {
          "read_only": true
        }
      }
    },
    "product_name": {
      "type": "string",
      "title": "Product Name",
      "propertyOrder": 4,
      "options": {
        "grid_columns": 6,
        "wb": {
          "read_only": true
        }
      }
    },
    "gtin": {
      "type": "number",
      "title": "Global Trade Item Number",
      "propertyOrder": 5,
      "options": {
        "grid_columns": 6,
        "wb": {
          "read_only": true
        }
      }
    },
    "identification_number": {
      "type": "number",
      "title": "Identification Number",
      "propertyOrder": 6,
      "options": {
        "grid_columns": 6,
        "wb": {
          "read_only": true
        }
      }
    },
    "firmware_version": {
      "type": "string",
      "title": "Firmware Version",
      "propertyOrder": 7,
      "options": {
        "grid_columns": 6,
        "wb": {
          "read_only": true
        }
      }
    },
    "hardware_version": {
      "type": "string",
      "title": "Hardware Version",
      "propertyOrder": 8,
      "options": {
        "grid_columns": 6,
        "wb": {
          "read_only": true
        }
      }
    },
    "part101_version": {
      "type": "string",
      "title": "DALI Part 101 Version",
      "propertyOrder": 9,
      "options": {
        "grid_columns": 4,
        "wb": {
          "read_only": true
        }
      }
    },
    "part102_version": {
      "type": "string",
      "title": "DALI Part 102 Version",
      "propertyOrder": 10,
      "options": {
        "grid_columns": 4,
        "wb": {
          "read_only": true
        }
      }
    },
    "part103_version": {
      "type": "string",
      "title": "DALI Part 103 Version",
      "propertyOrder": 11,
      "options": {
        "grid_columns": 4,
        "wb": {
          "read_only": true
        }
      }
    },
    "oem_gtin": {
      "type": "number",
      "title": "OEM Global Trade Item Number",
      "propertyOrder": 12,
      "options": {
        "grid_columns": 6,
        "wb": {
          "read_only": true
        }
      }
    },
    "oem_identification_number": {
      "type": "number",
      "title": "OEM Identification Number",
      "propertyOrder": 13,
      "options": {
        "grid_columns": 6,
        "wb": {
          "read_only": true
        }
      }
    },
    "short_address": {
      "type": "number",
      "title": "Short Address",
      "propertyOrder": 14,
      "minimum": 0,
      "maximum": 63,
      "default": 0,
      "options": {
        "grid_columns": 6
      }
    },
    "random_address": {
      "type": "number",
      "title": "Random Address",
      "propertyOrder": 15,
      "options": {
        "grid_columns": 6,
        "wb": {
          "read_only": true
        }
      }
    },
    "groups": {
      "type": "array",
      "title": "Groups",
      "propertyOrder": 18,
      "minItems": 16,
      "maxItems": 16,
      "items": {
        "type": "boolean",
        "format": "button"
      }
    },
    "fade_time": {
      "type": "number",
      "title": "Fade Time",
      "propertyOrder": 19,
      "minimum": 0,
      "maximum": 15,
      "default": 1,
      "options": {
        "grid_columns": 6
      }
    },
    "fade_rate": {
      "type": "number",
      "title": "Fade Rate",
      "propertyOrder": 20,
      "minimum": 1,
      "maximum": 15,
      "default": 1,
      "options": {
        "grid_columns": 6
      }
    }
  },

  "translations": {
    "ru": {
      "Global Trade Item Number": "Глобальный номер торговой единицы (GTIN)",
      "Identification Number": "Идентификационный номер",
      "Firmware Version": "Версия прошивки",
      "Hardware Version": "Версия аппаратного обеспечения",
      "DALI Part 101 Version": "Версия части 101 стандарта DALI",
      "DALI Part 102 Version": "Версия части 102 стандарта DALI",
      "DALI Part 103 Version": "Версия части 103 стандарта DALI",
      "OEM Global Trade Item Number": "Глобальный номер торговой единицы OEM (GTIN)",
      "OEM Identification Number": "Идентификационный номер OEM",
      "Groups": "Группы",
      "Control Gear Types": "Типы оборудования",
      "Short Address": "Короткий адрес",
      "Random Address": "Случайный адрес",
      "Fade Time": "Время затухания",
      "Fade Rate": "Скорость затухания",
      "Device name": "Название устройства",
      "MQTT id of the device": "Идентификатор устройства в MQTT",
      "Used as part of the topic": "Используется как часть топика в MQTT"
    }
  }
}
