{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "type": "object",
    "title": "DALI gateway configuration",
    "configFile": {
        "path": "/etc/wb-mqtt-dali.conf",
        "service": "wb-mqtt-dali",
        "editor": "dali"
    },
    "definitions": {
        "device": {
            "type": "object",
            "properties": {
                "short": {
                    "type": "integer",
                    "title": "Short Address"
                },
                "random": {
                    "type": "integer",
                    "title": "Random Address"
                }
            },
            "required": ["short", "random"]
        },
        "bus": {
            "type": "object",
            "properties": {
                "enable_lunaton": {
                    "type": "boolean"
                },
                "devices": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/device"
                    }
                }
            },
            "required": ["devices"]
        },
        "gateway": {
            "type": "object",
            "properties": {
                "device_id": {
                    "type": "string"
                },
                "buses": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/bus"
                    },
                    "maxItems": 3
                }
            },
            "required": ["device_id", "buses"]
        }
    },
    "properties": {
        "debug": {
            "type": "boolean"
        },
        "gateways": {
            "type": "array",
            "items": {
                "$ref": "#/definitions/gateway"
            }
        }
    },
    "translations": {
        "ru": {
            "DALI gateway configuration": "Настройки шлюза DALI"
        }
    }
}
