{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "type": "object",
    "configFile": {
        "path": "/etc/wb-mqtt-dali.conf",
        "service": "wb-mqtt-dali"
    },
    "properties": {
        "debug": {
            "type": "boolean",
            "title": "Enable debug logging",
            "default": false,
            "format": "checkbox",
            "propertyOrder": 1,
            "options": {
                "wb": {
                    "show_editor": true
                }
            }
        },
        "entries": {
            "type": "array",
            "title": "Device Entries",
            "items": {
                "type": "object",
                "properties": {
                    "short": {
                        "type": "integer",
                        "title": "Short Address"
                    },
                    "random": {
                        "type": "integer",
                        "title": "Random Address"
                    }
                },
                "required": ["short", "random"]
            }
        }
    },
    "translations": {
        "ru": {
            "Enable debug logging": "Включить отладочные сообщения"
        }
    }
}
